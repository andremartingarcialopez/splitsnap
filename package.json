{
  "name": "splitsnap",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w @splitsnap/api",
    "dev:frontend": "npm run dev -w @splitsnap/web",
    "dev:api": "npm run dev:backend",
    "dev:web": "npm run dev:frontend",
    "build:backend": "npm run build -w @splitsnap/api",
    "build:frontend": "npm run build -w @splitsnap/web",
    "build:api": "npm run build:backend",
    "build:web": "npm run build:frontend",
    "lint:backend": "npm run lint -w @splitsnap/api",
    "lint:frontend": "npm run lint -w @splitsnap/web",
    "lint:api": "npm run lint:backend",
    "lint:web": "npm run lint:frontend",
    "typecheck:backend": "npm run typecheck -w @splitsnap/api",
    "typecheck:frontend": "npm run typecheck -w @splitsnap/web",
    "typecheck:api": "npm run typecheck:backend",
    "typecheck:web": "npm run typecheck:frontend",
    "test:backend": "npm run test -w @splitsnap/api",
    "test:api": "npm run test:backend",
    "db:generate": "npm run prisma:generate -w @splitsnap/api",
    "db:migrate": "npm run prisma:migrate -w @splitsnap/api",
    "docker:secrets": "bash scripts/prepare-docker-secrets.sh",
    "docker:up": "npm run docker:secrets && docker compose up -d --build",
    "docker:down": "docker compose down"
  },
  "engines": {
    "node": ">=20"
  }
}
