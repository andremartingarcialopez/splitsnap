NODE_ENV=development
PORT=3000
DATABASE_URL="mysql://splitsnap:splitsnap@localhost:3306/splitsnap"
CORS_ORIGIN="http://localhost:5173"
OCR_SPACE_API_KEY=
# OpenRouter (proveedor IA)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_HTTP_REFERER=http://localhost:5173
# true = mock OCR/IA (sin claves). false + claves reales = adapters de producción.
PIPELINE_MOCK=true
MAX_UPLOAD_MB=5
CALC_TOTAL_VARIANCE_THRESHOLD=0.05
STORAGE_DIR=
