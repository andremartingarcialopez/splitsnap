generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// Grupo reutilizable de participantes (MDD §3)
model Group {
  id          String   @id @default(uuid()) @db.Char(36)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  groupParticipants GroupParticipant[]
  ticketGroups      TicketGroup[]

  @@index([name], map: "idx_group_name")
  @@map("Group")
}

model Participant {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String?  @db.VarChar(100)
  photoUrl  String?  @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groupParticipants    GroupParticipant[]
  ticketParticipants   TicketParticipant[]
  productAssignments   ProductAssignment[]

  @@index([name], map: "idx_participant_name")
  @@map("Participant")
}

model GroupParticipant {
  id            String   @id @default(uuid()) @db.Char(36)
  groupId       String   @db.Char(36)
  participantId String   @db.Char(36)
  createdAt     DateTime @default(now())

  group       Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([groupId, participantId], map: "uq_group_participant")
  @@index([groupId], map: "idx_gp_group")
  @@index([participantId], map: "idx_gp_participant")
  @@map("GroupParticipant")
}

/// Ticket de restaurante (MDD §3) + sesión colaborativa v2
model Ticket {
  id                      String    @id @default(uuid()) @db.Char(36)
  title                   String    @db.VarChar(150)
  restaurantName          String?   @db.VarChar(150)
  ticketImageUrl          String    @db.VarChar(500)
  subtotal                Decimal?  @db.Decimal(10, 2)
  tax                     Decimal?  @db.Decimal(10, 2)
  discount                Decimal?  @default(0) @db.Decimal(10, 2)
  total                   Decimal?  @db.Decimal(10, 2)
  /// Total impreso en el recibo físico (referencia; no cambia al editar productos)
  printedTotal            Decimal?  @db.Decimal(10, 2)
  /// Tasa de impuesto efectiva fijada al escanear (tax / suma productos)
  scanTaxRate             Decimal?  @db.Decimal(8, 6)
  tipMode                 String    @default("GLOBAL") @db.VarChar(20)
  globalTipPercentage     Decimal?  @db.Decimal(5, 2)
  processingStatus        String    @default("PENDING") @db.VarChar(20)
  /// Flujo colaborativo v2: DRAFT, CREATED, WAITING_FOR_PARTICIPANTS, IN_PROGRESS, REVIEWING, FINISHED, REOPENED, CANCELLED
  sessionStatus           String    @default("DRAFT") @db.VarChar(30)
  /// Código público para /ticket/:shareCode (se genera al iniciar división)
  shareCode               String?   @unique @db.VarChar(16)
  expectedParticipantCount Int?
  divisionStartedAt       DateTime?
  rawOcrText              String?   @db.Text
  failureReason           String?   @db.VarChar(500)
  finalizedAt             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  ticketGroups       TicketGroup[]
  ticketParticipants TicketParticipant[]
  products           Product[]

  @@index([createdAt], map: "idx_ticket_created")
  @@index([processingStatus], map: "idx_ticket_status")
  @@index([sessionStatus], map: "idx_ticket_session_status")
  @@index([shareCode], map: "idx_ticket_share_code")
  @@index([finalizedAt], map: "idx_ticket_finalized")
  @@map("Ticket")
}

model TicketParticipant {
  id                      String    @id @default(uuid()) @db.Char(36)
  ticketId                String    @db.Char(36)
  participantId           String    @db.Char(36)
  individualTipPercentage Decimal?  @db.Decimal(5, 2)
  /// NOT_JOINED, CONNECTED, SELECTING, COMPLETED, DISCONNECTED, LEFT
  sessionStatus           String    @default("NOT_JOINED") @db.VarChar(20)
  /// PENDING, PAID — control manual del admin (sin pasarela de pago)
  paymentStatus           String    @default("PENDING") @db.VarChar(20)
  isAdmin                 Boolean   @default(false)
  avatarId                String?   @db.VarChar(50)
  displayName             String?   @db.VarChar(100)
  selectionSubmittedAt    DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  ticket      Ticket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Restrict)

  @@unique([ticketId, participantId], map: "uq_ticket_participant")
  @@index([ticketId], map: "idx_tp_ticket")
  @@index([participantId], map: "idx_tp_participant")
  @@index([sessionStatus], map: "idx_tp_session_status")
  @@index([paymentStatus], map: "idx_tp_payment_status")
  @@map("TicketParticipant")
}

model TicketGroup {
  id        String   @id @default(uuid()) @db.Char(36)
  ticketId  String   @db.Char(36)
  groupId   String   @db.Char(36)
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  group  Group  @relation(fields: [groupId], references: [id], onDelete: Restrict)

  @@unique([ticketId, groupId], map: "uq_ticket_group")
  @@map("TicketGroup")
}

/// Producto del ticket (MDD §3)
model Product {
  id              String   @id @default(uuid()) @db.Char(36)
  ticketId        String   @db.Char(36)
  name            String   @db.VarChar(150)
  unitPrice       Decimal  @db.Decimal(10, 2)
  detectedByAI    Boolean  @default(false)
  confidenceScore Decimal? @db.Decimal(5, 2)
  /// Agrupa líneas explotadas desde la misma línea OCR (opcional)
  lineGroupId     String?  @db.Char(36)
  /// Combo/paquete que no debe separarse en unidades
  isIndivisible   Boolean  @default(false)
  emoji           String?  @db.VarChar(10)
  createdAt       DateTime @default(now())

  ticket      Ticket              @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  assignments ProductAssignment[]

  @@index([ticketId], map: "idx_product_ticket")
  @@index([name], map: "idx_product_name")
  @@index([lineGroupId], map: "idx_product_line_group")
  @@map("Product")
}

/// Asignación producto ↔ participante (MDD §3)
model ProductAssignment {
  id            String   @id @default(uuid()) @db.Char(36)
  productId     String   @db.Char(36)
  participantId String   @db.Char(36)
  shareRatio    Decimal  @db.Decimal(10, 4)
  createdAt     DateTime @default(now())

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([productId, participantId], map: "uq_product_participant")
  @@index([productId], map: "idx_pa_product")
  @@index([participantId], map: "idx_pa_participant")
  @@map("ProductAssignment")
}
