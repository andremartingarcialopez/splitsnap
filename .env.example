# Variables para docker compose (copiar a .env en la raíz)
# Solo MySQL local: docker compose up -d mysql

MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=splitsnap
MYSQL_USER=splitsnap
MYSQL_PASSWORD=splitsnap

API_PORT=3000
WEB_PORT=80
CORS_ORIGIN=http://localhost

# Pipeline: true sin claves reales; false + secrets para producción
PIPELINE_MOCK=true
OCR_SPACE_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
# Legacy Gemini directo (opcional)
GEMINI_API_KEY=

MAX_UPLOAD_MB=5
CALC_TOTAL_VARIANCE_THRESHOLD=0.05

# Producción: preferir archivos en secrets/ (montados vía docker compose secrets)
# echo -n "tu-clave" > secrets/ocr_space_api_key
# echo -n "tu-clave" > secrets/gemini_api_key
